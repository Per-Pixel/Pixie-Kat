PORT=3001
NODE_ENV=development

# Frontend URL (used in password reset redirect links)
FRONTEND_URL=http://localhost:5173

# CORS allowed origin in production
CORS_ORIGIN=https://your-domain.com

# Supabase — get from app.supabase.com → Project Settings → API
# IMPORTANT: Use the SERVICE ROLE key here (never expose in browser)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# SmileCode API — get from smile.one merchant portal → Integration section
# IMPORTANT: also whitelist your server's public IP in the portal
SMILECODE_API_KEY=your-api-key
SMILECODE_CLIENT_ID=your-integration-id
SMILECODE_SECRET=your-secret-key

# Smilecoin API (smile.one Smilecoin — different from SmileCode above)
# Get from your Smile One merchant account (contact Smile One team for UID + KEY)
SC_EMAIL=your-smileone-email@example.com
SC_UID=your-smileone-uid
SC_KEY=your-smileone-key
SC_COUNTRY=in
SC_ALLOW_TEST_ORDER=false
